DEEPSEEK_API_KEY=

# Optional — per-task Claude execution timeout in seconds (default 1800)
ROMYQ_CLAUDE_TIMEOUT=1800

# Optional — use a different planning provider (any OpenAI-compatible endpoint).
# ROMYQ_PLANNER_API_KEY takes precedence over DEEPSEEK_API_KEY.
# ROMYQ_PLANNER_API_KEY=
# ROMYQ_PLANNER_BASE_URL=https://api.deepseek.com
# ROMYQ_PLANNER_MODEL=deepseek-chat
# ROMYQ_PLANNER_TIMEOUT=600
